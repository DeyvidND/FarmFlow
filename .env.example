# ФермериБГ API — copy to .env and fill in. Empty third-party keys fall back to
# safe dev stubs (cash checkout, stub image URLs, file-preview email).

# ── Core (required) ──
DATABASE_URL=postgresql://farmflow:fermeribg@localhost:5433/farmflow
REDIS_URL=redis://localhost:6379
# Min 32 chars (validated at boot) — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-string-of-at-least-32-characters
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ── Rate limiting / abuse protection ──
# Global backstop: max requests per client IP per window (ms). Abuse-prone routes
# (auth, checkout, reviews, contact) are tightened further in code.
RATE_LIMIT_DEFAULT=300
RATE_LIMIT_TTL_MS=60000
# Emergency kill switch ('true' disables all throttling).
RATE_LIMIT_DISABLED=false
# Express `trust proxy`: set to the number of proxy hops in front of the API in
# production (e.g. 1 behind nginx/Cloudflare) so the limiter keys on the real
# client IP. Leave empty for direct exposure / local dev (safe, non-spoofable).
TRUST_PROXY=
# Max multipart upload size per file, in MB.
MAX_UPLOAD_MB=8

# ── Public origins (used to build links in emails) ──
API_PUBLIC_URL=http://localhost:3001
PUBLIC_APP_URL=http://localhost:3000
STOREFRONT_URL=http://localhost:3003

# ── Email / SMTP (Resend) — leave SMTP_HOST empty for dev file-preview (.mail-preview/) ──
# Resend SMTP: host smtp.resend.com, user literally "resend", pass = API key (re_...).
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ФермериБГ <no-reply@fermeribg.com>
MAIL_PREVIEW_DIR=.mail-preview
# Reputation lanes (set once Resend is live). Empty = both fall back to SMTP_FROM.
EMAIL_TRANSACTIONAL_FROM=
EMAIL_BULK_FROM=
# Resend webhook signing secret (whsec_..., from the webhook's settings).
# Svix-verifies the bounce/complaint webhook.
RESEND_WEBHOOK_SECRET=
# Secret appended to the bounce-complaint webhook URL (?secret=...).
EMAIL_WEBHOOK_SECRET=
# Verify Resend webhook signatures (recommended). 'false' only for local
# testing without real Resend-signed messages.
EMAIL_WEBHOOK_VERIFY=true
# Newsletter: max recipients per send + per-recipient price (micro-€; 555 = €0.000555 = Resend cost ×1.5).
EMAIL_PUSH_MAX_RECIPIENTS=5000
EMAIL_PRICE_PER_RECIPIENT_MICRO=555
# Resend cost basis (margin view only; ~$0.0004 on the Pro $20/50k plan). Never charges.
EMAIL_COST_PER_RECIPIENT_MICRO=370

# ── Stripe — empty = cash-only checkout ──
STRIPE_SECRET_KEY=
# Account-endpoint secret: SaaS billing events (platform account).
STRIPE_WEBHOOK_SECRET=
# Connect-endpoint secret: order events on connected accounts. Needed for card
# orders to confirm — Stripe uses a separate endpoint+secret from the account one.
STRIPE_CONNECT_WEBHOOK_SECRET=

# ── Platform SaaS billing (the platform charges farms €30/mo + €2/broadcast) ──
# Recurring €30/mo Price id, created once on the PLATFORM Stripe account.
# Empty → billing disabled (checkout returns a clear error).
STRIPE_BILLING_PRICE_ID=
# Display/estimate only (the real charge is the Stripe price above). 3000 = €30.
BILLING_BASE_PRICE_STOTINKI=3000
# Days of full access after a failed payment before auto-suspend.
BILLING_GRACE_DAYS=7

# ── Cloudflare R2 image storage — empty = stub URLs ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=farmflow-product-images
R2_PUBLIC_URL=https://images.example.com

# ── Optional ──
GOOGLE_MAPS_API_KEY=

# ── Error monitoring (Sentry) — empty = disabled (app runs identically) ──
# Project DSN from sentry.io → Settings → Client Keys (DSN). Only 5xx server
# errors are sent; 4xx client errors are skipped to save quota.
SENTRY_DSN=
# Event tag separating prod from staging/dev. Defaults to NODE_ENV.
SENTRY_ENVIRONMENT=
# Performance-tracing sample rate 0..1. 0 = errors only (default).
SENTRY_TRACES_SAMPLE_RATE=0

# --- Horizontal scaling (see docs/superpowers/specs/2026-06-15-scale-prep-queues-design.md) ---
# Process role: all (default — HTTP + workers + scheduled jobs) | web (HTTP + enqueue) | worker (queues + scheduled jobs)
APP_ROLE=all
# Max Postgres connections this process opens. instances × DB_POOL_MAX must stay
# under Postgres max_connections (~100), else front Postgres with PgBouncer.
DB_POOL_MAX=10
