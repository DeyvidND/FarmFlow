# FarmFlow API — copy to .env and fill in. Empty third-party keys fall back to
# safe dev stubs (cash checkout, stub image URLs, file-preview email).

# ── Core (required) ──
DATABASE_URL=postgresql://farmflow:farmflow@localhost:5433/farmflow
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ── Public origins (used to build links in emails) ──
API_PUBLIC_URL=http://localhost:3001
PUBLIC_APP_URL=http://localhost:3000
STOREFRONT_URL=http://localhost:3003

# ── Email / SMTP — leave SMTP_HOST empty for dev file-preview (.mail-preview/) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=FarmFlow <no-reply@farmflow.bg>
MAIL_PREVIEW_DIR=.mail-preview

# ── Stripe — empty = cash-only checkout ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Cloudflare R2 image storage — empty = stub URLs ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=farmflow-product-images
R2_PUBLIC_URL=https://images.example.com

# ── Optional ──
GOOGLE_MAPS_API_KEY=
