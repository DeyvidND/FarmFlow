{
  "name": "@fermeribg/help-content",
  "version": "0.0.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "jest"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "<rootDir>/../tsconfig.json" }]
    },
    "testEnvironment": "node"
  },
  "devDependencies": {
    "typescript": "~5.6.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "@types/jest": "^29.5.14"
  }
}
