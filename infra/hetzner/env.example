# ФермериБГ core .env  — fill ON THE BOX (do not paste secrets into chat).
# Legend:  [NEW]=generate fresh   [COPY]=copy exact value from current Dokploy
#          [MATCH]=MUST equal current prod or data breaks   [URL]=your domains
#
# Image tag
IMAGE_TAG=latest

# --- internal DB/cache (NEW — internal only, generate: openssl rand -hex 32) ---
POSTGRES_PASSWORD=
REDIS_PASSWORD=

# --- crypto (MATCH current prod EXACTLY) ---
# ENCRYPTION_KEY decrypts data already in the DB → wrong value = broken Stripe/tokens.
ENCRYPTION_KEY=
JWT_SECRET=

# --- public URLs (URL — copy from current Dokploy) ---
CORS_ORIGIN=
PUBLIC_APP_URL=
API_PUBLIC_URL=
STOREFRONT_URL=
TRUST_PROXY=1

# --- super-admin bootstrap (only used if platform_admins empty; after restore, leave blank) ---
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# --- Stripe (COPY) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_BILLING_PRICE_ID=
STRIPE_PLATFORM_FEE_BPS=0
STRIPE_CONNECT_COUNTRY=BG

# --- Cloudflare R2 (COPY) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# --- Email / Resend (COPY) ---
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
EMAIL_TRANSACTIONAL_FROM=
EMAIL_BULK_FROM=
RESEND_WEBHOOK_SECRET=
EMAIL_WEBHOOK_SECRET=
EMAIL_WEBHOOK_VERIFY=true

# --- Google Maps (COPY) ---
GOOGLE_MAPS_API_KEY=

# --- Sentry (COPY, optional) ---
SENTRY_DSN_API=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0

# --- Standalone delivery app (dostavki.fermeribg.com — the `econt` service) ---
# CORS_ORIGIN_ECONT is also set in compose; APP_ROLE is forced to `web` there so the
# courier crons never double-run — do NOT set APP_ROLE globally here.
CORS_ORIGIN_ECONT=https://dostavki.fermeribg.com
# Bulk-import AI validation (optional — degrades to deterministic-only when unset).
OPENAI_API_KEY=
OPENAI_IMPORT_MODEL=gpt-4o-mini
# COD-risk registry bridge (optional — inert until key set + THIS box's IP is
# whitelisted in the nekorekten.com dashboard + a paid tier is chosen).
NEKOREKTEN_API_KEY=
# Speedy fallback serviceId when a tenant hasn't set its own. SPIKE: verify the real
# id via Speedy /services/destination before trusting it.
SPEEDY_DEFAULT_SERVICE_ID=

# --- Cloudflare Tunnel (NEW — create a new tunnel for THIS box, paste its token) ---
# After deploy, add a PUBLIC HOSTNAME on the tunnel:
#   dostavki.fermeribg.com  ->  http://econt:3100
CF_TUNNEL_TOKEN=
