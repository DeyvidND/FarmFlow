# Public API base URL (CORS `*`, no auth). Defaults to http://localhost:3001.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Tenant slug for this deploy (single-farm). Available client-side.
# `?slug=` in the URL overrides this for local multi-tenant testing.
NEXT_PUBLIC_STOREFRONT_SLUG=ferma-petrovi

# Server-only fallback slug (used if NEXT_PUBLIC_STOREFRONT_SLUG is unset).
STOREFRONT_SLUG=ferma-petrovi

# Google Maps browser key (Maps JavaScript + Places). Empty = plain address
# input (server still geocodes). Restrict by HTTP referrer in Google Cloud.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
