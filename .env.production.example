# Production env for the Dokploy "Docker Compose" application.
# Copy the values into the Dokploy app's Environment. NOTHING secret belongs in
# git — this file is a template only.
#
# Two kinds of variables:
#   1) RUNTIME — injected into containers by docker-compose.prod.yml (below).
#   2) BUILD-TIME — NEXT_PUBLIC_* baked into the web image by
#      .github/workflows/deploy.yml. Set those as GitHub Actions *Repository
#      variables* (Settings → Secrets and variables → Actions → Variables),
#      NOT here. Listed at the bottom for reference.
#
# This monorepo deploys api + web (admin panel) + admin (super-admin panel).
# The customer shop is the SEPARATE pazar-chaika repo, not built here.

# ── Compose routing / image (used by docker-compose.prod.yml) ──
IMAGE_TAG=latest
API_DOMAIN=api.fermeribg.com
WEB_DOMAIN=app.fermeribg.com
ADMIN_DOMAIN=admin.fermeribg.com

# ── Core (API) ──
# Postgres + Redis run as the SEPARATE Dokploy compose app docker-compose.infra.yml.
# Reach them by service name over the shared dokploy-network. POSTGRES_PASSWORD is
# set in the INFRA app's env; reuse the same value here.
DATABASE_URL=postgresql://farmflow:POSTGRES_PASSWORD@farmflow-postgres:5432/farmflow
# Redis in docker-compose.infra.yml runs with --requirepass, so the URL MUST carry
# the password. REDIS_PASSWORD is set in the INFRA app's env; reuse the same value.
REDIS_PASSWORD=__long-random__
REDIS_URL=redis://:REDIS_PASSWORD@farmflow-redis:6379
JWT_SECRET=__long-random-unique-to-prod__
ENCRYPTION_KEY=__random__   # without it, Econt credentials can't be saved
# Behind Traefik/Cloudflare — number of proxy hops for correct client-IP keying.
TRUST_PROXY=1
# Comma-separated allowlist (dashboard + admin panel + any first-party origin).
CORS_ORIGIN=https://app.fermeribg.com,https://admin.fermeribg.com
PUBLIC_APP_URL=https://app.fermeribg.com
# Recipient for the critical-problem alert cron (server errors / empty shop) —
# separate from SUPER_ADMIN_EMAIL so it can be routed differently later.
CRITICAL_ALERT_EMAIL=
ADMIN_PANEL_URL=https://admin.fermeribg.com

# ── Rate limiting / abuse protection ──
# Global backstop: max requests per client IP per window (ms). Abuse-prone routes
# (auth, checkout, reviews, contact) are tightened further in code. Defaults are
# safe if omitted; shown here so the knobs are discoverable.
RATE_LIMIT_DEFAULT=300
RATE_LIMIT_TTL_MS=60000
# Emergency kill switch ('true' disables ALL throttling — leave false).
RATE_LIMIT_DISABLED=false
# Max multipart upload size per file, in MB.
MAX_UPLOAD_MB=8
API_PUBLIC_URL=https://api.fermeribg.com
# Public customer shop = the separate pazar-chaika (Astro) app. Used for the
# shop links the API embeds in emails. Point at the pazar deploy domain.
STOREFRONT_URL=https://pazar.fermeribg.com

# ── Stripe (LIVE) ──
STRIPE_SECRET_KEY=sk_live_...
# Account endpoint (platform events: billing/invoices/subscriptions).
STRIPE_WEBHOOK_SECRET=whsec_...
# Connect endpoint (connected-account events: order charges/refunds). REQUIRED for
# card orders to confirm — a separate Stripe endpoint with its own signing secret.
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...
STRIPE_BILLING_PRICE_ID=price_...
STRIPE_PLATFORM_FEE_BPS=0
STRIPE_CONNECT_COUNTRY=BG

# ── Cloudflare R2 ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Serve images from the sending domain, NOT the raw pub-*.r2.dev dev URL — Resend
# flags off-domain image hosts (Gmail spam signal). Attach cdn.fermeribg.com as the
# bucket's R2 custom domain first, then set this. Migration 0060 rewrites existing
# baked pub-*.r2.dev URLs to match.
R2_PUBLIC_URL=https://cdn.fermeribg.com

# ── Email / Resend ──
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=                          # Resend API key (re_...)
# Use a real MONITORED, replyable mailbox — not no-reply@ (Resend: a one-way From
# lowers inbox trust). EMAIL_REPLY_TO routes replies even if From stays branded.
EMAIL_TRANSACTIONAL_FROM=ФермериБГ <pozdravi@fermeribg.com>
EMAIL_BULK_FROM=ФермериБГ Новини <news@fermeribg.com>
EMAIL_REPLY_TO=pozdravi@fermeribg.com
# Resend dashboard → Webhooks → the endpoint's Signing Secret (whsec_...).
RESEND_WEBHOOK_SECRET=
EMAIL_WEBHOOK_SECRET=__random__
EMAIL_WEBHOOK_VERIFY=true

# Sentry — backend (api) error monitoring. RUNTIME env, set here in Dokploy.
# Maps to the api container's SENTRY_DSN. Use the "Node/NestJS" project DSN.
# Empty = disabled. SENTRY_TRACES_SAMPLE_RATE>0 turns on performance tracing.
SENTRY_DSN_API=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0

# ════════════════════════════════════════════════════════════════════════════
# BUILD-TIME (GitHub Actions → Repository VARIABLES, baked into the image):
#   FF_MAPS_BROWSER_KEY          -> web   NEXT_PUBLIC_GOOGLE_MAPS_API_KEY
#   FF_STRIPE_PUBLISHABLE_KEY    -> web   NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY (pk_live_...)
#   FF_SENTRY_DSN_PANEL          -> web   NEXT_PUBLIC_SENTRY_DSN (Sentry "Next.js" panel project)
#   FF_SENTRY_DSN_ADMIN          -> admin NEXT_PUBLIC_SENTRY_DSN (Sentry "Next.js" admin project)
#   (browser DSNs are public — repo VARIABLES, not secrets. Empty = Sentry off.
#    changing one needs a rebuild, not just a redeploy.)
#
# Dokploy redeploy webhook (GitHub Actions → Secrets):
#   DOKPLOY_FARMFLOW_WEBHOOK   -> the apps compose Dokploy app's deploy webhook
#
# INFRA app (docker-compose.infra.yml) — set in ITS Dokploy Environment, NOT here:
#   POSTGRES_PASSWORD=__long-random__   (reuse inside DATABASE_URL above)
# ════════════════════════════════════════════════════════════════════════════
