# Production env for the Dokploy "Docker Compose" application.
# Copy the values into the Dokploy app's Environment. NOTHING secret belongs in
# git — this file is a template only.
#
# Two kinds of variables:
#   1) RUNTIME — injected into containers by docker-compose.prod.yml (below).
#   2) BUILD-TIME — NEXT_PUBLIC_* baked into the web image by
#      .github/workflows/deploy.yml. Set those as GitHub Actions *Repository
#      variables* (Settings → Secrets and variables → Actions → Variables),
#      NOT here. Listed at the bottom for reference.
#
# This monorepo deploys api + web (admin panel) + admin (super-admin panel).
# The customer shop is the SEPARATE pazar-chaika repo, not built here.

# ── Compose routing / image (used by docker-compose.prod.yml) ──
IMAGE_TAG=latest
API_DOMAIN=api.farmsteadflow.com
WEB_DOMAIN=app.farmsteadflow.com
ADMIN_DOMAIN=admin.farmsteadflow.com

# ── Core (API) ──
# Postgres + Redis run as the SEPARATE Dokploy compose app docker-compose.infra.yml.
# Reach them by service name over the shared dokploy-network. POSTGRES_PASSWORD is
# set in the INFRA app's env; reuse the same value here.
DATABASE_URL=postgresql://farmflow:POSTGRES_PASSWORD@farmflow-postgres:5432/farmflow
REDIS_URL=redis://farmflow-redis:6379
JWT_SECRET=__long-random-unique-to-prod__
ENCRYPTION_KEY=__random__   # without it, Econt credentials can't be saved
# Behind Traefik/Cloudflare — number of proxy hops for correct client-IP keying.
TRUST_PROXY=1
# Comma-separated allowlist (dashboard + admin panel + any first-party origin).
CORS_ORIGIN=https://app.farmsteadflow.com,https://admin.farmsteadflow.com
PUBLIC_APP_URL=https://app.farmsteadflow.com
API_PUBLIC_URL=https://api.farmsteadflow.com
# Public customer shop = the separate pazar-chaika (Astro) app. Used for the
# shop links the API embeds in emails. Point at the pazar deploy domain.
STOREFRONT_URL=https://pazar.farmsteadflow.com

# ── Stripe (LIVE) ──
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_BILLING_PRICE_ID=price_...
STRIPE_PLATFORM_FEE_BPS=0
STRIPE_CONNECT_COUNTRY=BG

# ── Cloudflare R2 ──
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── Email / Amazon SES ──
SMTP_HOST=email-smtp.eu-central-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_TRANSACTIONAL_FROM=FarmFlow <no-reply@farmsteadflow.com>
EMAIL_BULK_FROM=FarmFlow Новини <news@farmsteadflow.com>
SES_CONFIG_SET_TRANSACTIONAL=farmsteadflow-transactional
SES_CONFIG_SET_BULK=farmsteadflow-bulk
EMAIL_WEBHOOK_SECRET=__random__
EMAIL_SNS_VERIFY=true

# ════════════════════════════════════════════════════════════════════════════
# BUILD-TIME (GitHub Actions → Repository VARIABLES, baked into the web image):
#   FF_MAPS_BROWSER_KEY          -> web NEXT_PUBLIC_GOOGLE_MAPS_API_KEY
#   FF_STRIPE_PUBLISHABLE_KEY    -> web NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY (pk_live_...)
#
# Dokploy redeploy webhook (GitHub Actions → Secrets):
#   DOKPLOY_FARMFLOW_WEBHOOK   -> the apps compose Dokploy app's deploy webhook
#
# INFRA app (docker-compose.infra.yml) — set in ITS Dokploy Environment, NOT here:
#   POSTGRES_PASSWORD=__long-random__   (reuse inside DATABASE_URL above)
# ════════════════════════════════════════════════════════════════════════════
