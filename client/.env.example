# Farmer dashboard (port 3000). Copy to .env.
# Base URL of the FarmFlow API. Server-only — the /bff proxy and /api/session
# routes read it; it is never exposed to the browser. Defaults to :3001.
API_URL=http://localhost:3001

# Google Maps browser key (Maps JavaScript). Empty = demo placeholder map.
# Restrict by HTTP referrer in Google Cloud.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Stripe publishable key (pk_…) for the embedded Connect components on the
# Плащания page. Empty = page shows "not configured". Pair with the API's
# STRIPE_SECRET_KEY. Publishable keys are safe to expose in the browser.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
