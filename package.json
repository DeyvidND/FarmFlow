{
  "name": "fermeribg",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @fermeribg/db generate",
    "db:migrate": "pnpm --filter @fermeribg/db migrate",
    "db:seed": "pnpm --filter @fermeribg/db seed",
    "docs:check": "node scripts/check-docs-fresh.mjs"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "~5.6.0"
  },
  "pnpm": {
    "overrides": {
      "multer": ">=2.2.0",
      "qs": ">=6.15.2",
      "postcss": ">=8.5.10",
      "js-yaml": ">=4.1.1"
    }
  }
}
